// 慧对接 SmartConnect — Prisma Schema (v0.1)
// 对齐 docs/DATA_MODEL.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ 枚举 ============

enum EntrySource {
  platform
  b_only
}

enum AuditStatus {
  pending
  approved
  rejected
}

enum JoinMode {
  free
  paid
}

enum UserStatus {
  active
  frozen
}

enum SwapSetting {
  auto_approve
  manual_review
}

enum BTenantStatus {
  active
  disabled
}

enum AdminRole {
  super
  operator
}

// ============ 平台管理员(全局表) ============

model PlatformAdmin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         AdminRole @default(operator)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("platform_admin")
}

// ============ 项目类别字典(全局表) ============

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  sort  Int    @default(0)

  projects Project[]

  @@map("category")
}

// ============ B端租户 ============

model BTenant {
  id            Int           @id @default(autoincrement())
  phone         String        @unique
  passwordHash  String        @map("password_hash")
  name          String
  cityCenterId  Int?          @map("city_center_id")
  status        BTenantStatus @default(active)
  feeCap        Int           @default(99900) @map("fee_cap")
  commissionRate Int          @default(10) @map("commission_rate") // 百分比 0-100
  moduleConfig  Json          @default("{}") @map("module_config")
  createdAt     DateTime      @default(now()) @map("created_at")

  projects             Project[]
  userTenantRelations  UserTenantRelation[]
  userReferrals        UserReferral[]
  userFavorites        UserFavorite[]
  userJoins            UserJoin[]
  cOrders              COrder[]
  bOrders              BOrder[]
  projectDynamics      ProjectDynamic[]
  initTokens           BInitToken[]
  commissions          Commission[]

  @@map("b_tenant")
}

// ============ 城市运营中心(租户表) ============

model CityCenter {
  id            Int      @id @default(autoincrement())
  bId           Int      @map("b_id")
  cityName      String   @map("city_name")
  address       String?
  contactName   String?  @map("contact_name")
  contactWechat String?  @map("contact_wechat")
  contactPhone  String?  @map("contact_phone")
  activity      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("city_center")
}

// ============ 项目(租户表) ============

model Project {
  id            Int         @id @default(autoincrement())
  bId           Int         @map("b_id")
  categoryId    Int         @map("category_id")
  title         String
  oneLiner      String      @map("one_liner")
  intro         String?
  vision        String?
  goals         String?
  team          String?
  technology    String?
  competition   String?
  requirements  String?
  swot          Json?
  companyInfo   Json?       @map("company_info")
  qccUrl        String?     @map("qcc_url")
  founderIntro  String?     @map("founder_intro")
  originStory   String?     @map("origin_story")
  bpContent     String?     @map("bp_content")
  bpPrice       Int         @default(0) @map("bp_price")
  joinPrice     Int         @default(0) @map("join_price")
  joinMode      JoinMode    @default(free) @map("join_mode")
  joinRequirement String?
  auditStatus   AuditStatus @default(pending) @map("audit_status")
  createdAt     DateTime    @default(now()) @map("created_at")

  bTenant           BTenant           @relation(fields: [bId], references: [id])
  category          Category          @relation(fields: [categoryId], references: [id])
  score             ProjectScore?
  dynamics          ProjectDynamic[]
  userJoins         UserJoin[]
  scoreReviews      UserScoreReview[]
  expertAnalysis    ProjectExpertAnalysis?

  @@index([bId, categoryId])
  @@index([auditStatus])
  @@map("project")
}

// ============ 项目评分(租户表) ============

model ProjectScore {
  id             Int      @id @default(autoincrement())
  projectId      Int      @unique @map("project_id")
  bId            Int      @map("b_id")
  authenticity   Int      @default(50) // 0-100 越高越好
  risk           Int      @default(50) // 0-100 越高越危险
  profitability  Int      @default(50) // 0-100 越高越好
  reviewCount    Int      @default(0) @map("review_count")
  initialSource  String   @default("platform") @map("initial_source")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([bId])
  @@map("project_score")
}

// ============ 专家分析(租户表,v0.2) ============

model ProjectExpertAnalysis {
  id         Int      @id @default(autoincrement())
  projectId  Int      @unique @map("project_id")
  bId        Int      @map("b_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([bId])
  @@map("project_expert_analysis")
}

// ============ 项目动态(租户表) ============

model ProjectDynamic {
  id         Int      @id @default(autoincrement())
  projectId  Int      @map("project_id")
  bId        Int      @map("b_id")
  title      String
  content    String?
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project  @relation(fields: [projectId], references: [id])
  bTenant  BTenant  @relation(fields: [bId], references: [id])

  @@index([bId])
  @@map("project_dynamic")
}

// ============ C端用户全局身份(全局表,不含敏感) ============

model CUser {
  id        Int        @id @default(autoincrement())
  phone     String?    @unique
  openid    String     @unique
  unionid   String?
  nickname  String?
  avatar    String?
  status    UserStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at")

  tenantRelations  UserTenantRelation[]
  resources        UserResource[]
  favorites        UserFavorite[]
  joins            UserJoin[]
  referralsMade    UserReferral[]      @relation("ReferrerReferrals")
  referralsReceived UserReferral[]     @relation("ReferredReferrals")
  scoreReviews     UserScoreReview[]
  cOrders          COrder[]
  commissions      Commission[]
  kyc              UserKyc?

  @@map("c_user")
}

// ============ 用户-B端关系(关系表,带b_id,启用RLS) ============

model UserTenantRelation {
  id            Int          @id @default(autoincrement())
  userId        Int          @map("user_id")
  bId           Int          @map("b_id")
  relationFlags Int          @default(1) @map("relation_flags") // 位掩码:1=primary 2=visited 4=joined
  entrySource   EntrySource  @map("entry_source")
  parentUserId  Int?         @map("parent_user_id")
  swapSetting   SwapSetting  @default(manual_review) @map("swap_setting")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  cUser   CUser   @relation(fields: [userId], references: [id])
  bTenant BTenant @relation(fields: [bId], references: [id])

  @@unique([userId, bId])
  @@index([bId])
  @@map("user_tenant_relation")
}

// ============ 用户资源/需求(全局表,可选visible_b_id) ============

model UserResource {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  type         String   // resource / demand
  content      String
  visibility   String   @default("public") // public / b_only / hidden
  visibleBId   Int?     @map("visible_b_id")
  createdAt    DateTime @default(now()) @map("created_at")

  cUser CUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_resource")
}

// ============ 收藏(租户表) ============

model UserFavorite {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  bId         Int      @map("b_id")
  targetType   String   @map("target_type") // project / city_center
  targetId    Int      @map("target_id")
  createdAt   DateTime @default(now()) @map("created_at")

  cUser   CUser   @relation(fields: [userId], references: [id])
  bTenant BTenant @relation(fields: [bId], references: [id])

  @@unique([userId, targetType, targetId])
  @@map("user_favorite")
}

// ============ 加入项目(租户表) ============

model UserJoin {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  bId           Int      @map("b_id")
  projectId     Int      @map("project_id")
  joinedAt      DateTime @default(now()) @map("joined_at")
  unlockContact Boolean  @default(false) @map("unlock_contact")

  cUser   CUser   @relation(fields: [userId], references: [id])
  bTenant BTenant @relation(fields: [bId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@index([bId, projectId])
  @@map("user_join")
}

// ============ 推荐关系(租户表,一级,限定B端内) ============

model UserReferral {
  id          Int      @id @default(autoincrement())
  bId         Int      @map("b_id")
  referrerId  Int      @map("referrer_id")
  referredId  Int      @map("referred_id")
  createdAt   DateTime @default(now()) @map("created_at")

  bTenant   BTenant @relation(fields: [bId], references: [id])
  referrer  CUser   @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referred  CUser   @relation("ReferredReferrals", fields: [referredId], references: [id])

  @@unique([referredId, bId])
  @@map("user_referral")
}

// ============ 项目评价(租户表,v0.2) ============

model UserScoreReview {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  projectId     Int      @map("project_id")
  bId           Int      @map("b_id")
  authenticity  Int      // 1-5
  risk          Int      // 1-5
  profitability Int      // 1-5
  createdAt     DateTime @default(now()) @map("created_at")

  cUser   CUser   @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@map("user_score_review")
}

// ============ C端订单(租户表,v0.2) ============

model COrder {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  bId           Int      @map("b_id")
  projectId     Int?     @map("project_id")
  type          String   // bp_unlock / join_project / partner
  amount        Int      // 分
  status        String   @default("created") // created/pending/paid/delivered/closed/refunded/partial_refunded
  wxTradeNo     String?  @map("wx_trade_no")
  refundAmount  Int      @default(0) @map("refund_amount")
  createdAt     DateTime @default(now()) @map("created_at")
  paidAt        DateTime? @map("paid_at")
  deliveredAt   DateTime? @map("delivered_at")
  closedAt      DateTime? @map("closed_at")

  cUser   CUser   @relation(fields: [userId], references: [id])
  bTenant BTenant @relation(fields: [bId], references: [id])
  commissions Commission[]

  @@index([bId, status])
  @@map("c_order")
}

// ============ B端订单(租户表,v0.2) ============

model BOrder {
  id         Int      @id @default(autoincrement())
  bId        Int      @map("b_id")
  type       String   // publish / service
  amount     Int
  status     String   @default("created")
  wxTradeNo  String?  @map("wx_trade_no")
  createdAt  DateTime @default(now()) @map("created_at")
  paidAt     DateTime? @map("paid_at")
  closedAt   DateTime? @map("closed_at")

  bTenant BTenant @relation(fields: [bId], references: [id])

  @@map("b_order")
}

// ============ B 端初始化 token（一次性，30 分钟过期） ============

model BInitToken {
  id          Int      @id @default(autoincrement())
  bId         Int      @map("b_id")
  tokenHash   String   @unique @map("token_hash")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  bTenant BTenant @relation(fields: [bId], references: [id])

  @@index([bId])
  @@map("b_init_token")
}

// ============ 分佣记录(v0.2) ============

model Commission {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  referrerId  Int      @map("referrer_id")
  bId         Int      @map("b_id")
  amount      Int
  rate        Int
  status      String   @default("pending") // pending/frozen/settled/reversed
  settleBatch String?  @map("settle_batch")
  createdAt   DateTime @default(now()) @map("created_at")
  settledAt   DateTime? @map("settled_at")

  order    COrder @relation(fields: [orderId], references: [id])
  referrer CUser  @relation(fields: [referrerId], references: [id])
  bTenant  BTenant @relation(fields: [bId], references: [id])

  @@index([referrerId, status])
  @@index([bId])
  @@map("commission")
}

// ============ 实名认证KYC(v0.2) ============

model UserKyc {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  realName    String   @map("real_name")
  idCardHash  String   @map("id_card_hash")
  idCardEnc   String   @map("id_card_enc")
  verified    String   @default("pending") // pending/approved/rejected
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime @default(now()) @map("created_at")

  cUser CUser @relation(fields: [userId], references: [id])

  @@map("user_kyc")
}
