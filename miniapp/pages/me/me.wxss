.me { padding: 24rpx; }
.profile { background: #fff; border-radius: 12rpx; padding: 32rpx 24rpx; margin-bottom: 24rpx; }
.phone { font-size: 34rpx; font-weight: 600; }
.src { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.tabs { display: flex; margin-bottom: 24rpx; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab.active { color: #1a73e8; border-bottom-color: #1a73e8; font-weight: 600; }
.item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; font-size: 28rpx; }
.sub { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.empty { text-align: center; color: #999; padding: 48rpx; }
